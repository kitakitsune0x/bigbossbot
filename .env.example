# Local host URL for non-Docker development. Docker Compose overrides this internally.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54329/big_boss
AUTH_ENCRYPTION_KEY=replace-with-a-long-random-secret-value
AUTH_ENCRYPTION_KEY_FALLBACKS=
SESSION_COOKIE_NAME=big_boss_session
AUTH_SESSION_DAYS=30
AUTH_REQUIRE_2FA=false
BOOTSTRAP_ADMIN_USERNAME=big_boss_admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password

# Local MCP sidecar defaults
BIG_BOSS_BASE_URL=http://127.0.0.1:3000
BIG_BOSS_API_TOKEN=

# Local MCP sidecar defaults
BIG_BOSS_BASE_URL=http://127.0.0.1:3000
BIG_BOSS_API_TOKEN=
