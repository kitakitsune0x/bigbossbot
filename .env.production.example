# VPS runtime secrets. Copy this file to .env.production on the server only.
# Do not commit the real .env.production file.

# Docker image to deploy.
# Use :latest for automatic updates, or pin a specific date tag such as :2026.04.15 for rollback.
BIG_BOSS_IMAGE=ghcr.io/kitakitsune0x/bigbossbot:latest

# Public hostname that already points to this VM.
APP_DOMAIN=example.com

# Database configuration for the bundled Postgres service.
POSTGRES_DB=big_boss
POSTGRES_USER=bigboss
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://bigboss:replace-with-a-long-random-password@postgres:5432/big_boss

# App secrets and auth.
AUTH_ENCRYPTION_KEY=replace-with-a-long-random-secret
AUTH_ENCRYPTION_KEY_FALLBACKS=
SESSION_COOKIE_NAME=big_boss_session
AUTH_SESSION_DAYS=30
AUTH_REQUIRE_2FA=false
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
INTEL_SHARED_SECRET=replace-with-a-long-random-secret
INTEL_LOG_LEVEL=INFO

# Auto-update cadence in seconds for Watchtower.
WATCHTOWER_POLL_INTERVAL=60
